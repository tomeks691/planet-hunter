[Unit]
Description=Planet Hunter Pipeline
After=network.target

[Service]
Type=simple
User=lucek
WorkingDirectory=/home/lucek/planet-hunter
ExecStart=/usr/bin/python3 -m uvicorn planet_hunter.main:app --host 0.0.0.0 --port 8420
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
